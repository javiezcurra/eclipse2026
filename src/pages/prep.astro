---
import Base from '../layouts/Base.astro';
import { prepItems } from '../data/prep';
import type { PrepItem } from '../data/types';

const categoryLabel: Record<PrepItem['category'], string> = {
  documents: 'Documents',
  tech: 'Tech & connectivity',
  health: 'Health',
  money: 'Money',
  packing: 'Packing',
  other: 'Other',
};

const groups = new Map<PrepItem['category'], PrepItem[]>();
for (const item of prepItems) {
  const list = groups.get(item.category) ?? [];
  list.push(item);
  groups.set(item.category, list);
}
// Documents first, then Tech & connectivity, then the rest.
const orderedCategories: PrepItem['category'][] = ['documents', 'tech', 'health', 'money', 'packing', 'other'];
---

<Base title="Prep">
  <header class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight text-fg-strong sm:text-3xl">Before the trip</h1>
    <p class="mt-1 text-sm text-fg-muted">Things to think about and do before we leave.</p>
  </header>

  <div class="space-y-6">
    {orderedCategories.map((cat) => {
      const items = groups.get(cat);
      if (!items?.length) return null;
      return (
        <section>
          <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-fg-muted">{categoryLabel[cat]}</h2>
          <ul class="space-y-2">
            {items.map((item) => (
              <li class="rounded-xl border border-line bg-card p-4">
                <div class="flex items-start justify-between gap-3">
                  <h3 class="text-sm font-semibold text-fg-strong sm:text-base">{item.title}</h3>
                  {item.deadline && (
                    <span class="shrink-0 rounded-full border border-line bg-card-2 px-2 py-0.5 text-[10px] uppercase tracking-wider text-fg-muted">{item.deadline}</span>
                  )}
                </div>
                {item.description && <p class="mt-1 text-sm text-fg">{item.description}</p>}

                {item.links && item.links.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {item.links.map((l) => (
                      <a
                        href={l.url}
                        target="_blank"
                        rel="noopener"
                        class="inline-flex items-center gap-1.5 rounded-lg border border-line bg-card-2 px-3 py-1.5 text-xs font-medium text-fg hover:border-line-strong hover:text-fg-strong"
                      >
                        {l.label}
                        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
                      </a>
                    ))}
                  </div>
                )}

                {item.action === 'open-install-modal' && (
                  <div class="mt-3">
                    <button
                      type="button"
                      data-action="open-install-modal"
                      class="inline-flex items-center gap-2 rounded-lg bg-sun-500 px-3 py-1.5 text-xs font-semibold text-slate-900 hover:bg-sun-400"
                    >
                      <span aria-hidden="true">📱</span>
                      {item.actionLabel ?? 'Show install instructions'}
                    </button>
                  </div>
                )}
              </li>
            ))}
          </ul>
        </section>
      );
    })}
  </div>
</Base>

<script>
  // Wire up the install-modal trigger button. The install modal itself is
  // rendered by InstallBanner.astro (loaded in Base.astro), so it's present
  // in the DOM on every page even if the banner isn't visible.
  for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-action="open-install-modal"]')) {
    btn.addEventListener('click', () => {
      const modal = document.getElementById('install-modal') as HTMLDialogElement | null;
      modal?.showModal();
    });
  }
</script>
