---
import Base from '../layouts/Base.astro';
import { prepItems } from '../data/prep';
import type { PrepItem } from '../data/types';

const categoryLabel: Record<PrepItem['category'], string> = {
  documents: 'Documents',
  health: 'Health',
  tech: 'Tech & connectivity',
  money: 'Money',
  packing: 'Packing',
  other: 'Other',
};

const groups = new Map<PrepItem['category'], PrepItem[]>();
for (const item of prepItems) {
  const list = groups.get(item.category) ?? [];
  list.push(item);
  groups.set(item.category, list);
}
const orderedCategories: PrepItem['category'][] = ['documents', 'health', 'tech', 'money', 'packing', 'other'];
---

<Base title="Prep">
  <header class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight text-slate-100 sm:text-3xl">Before the trip</h1>
    <p class="mt-1 text-sm text-slate-400">Things to think about and do before we leave.</p>
  </header>

  <div class="space-y-6">
    {orderedCategories.map((cat) => {
      const items = groups.get(cat);
      if (!items?.length) return null;
      return (
        <section>
          <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-400">{categoryLabel[cat]}</h2>
          <ul class="space-y-2">
            {items.map((item) => (
              <li class="rounded-xl border border-night-800 bg-night-900/60 p-4">
                <div class="flex items-start justify-between gap-3">
                  <h3 class="text-sm font-semibold text-slate-100 sm:text-base">{item.title}</h3>
                  {item.deadline && (
                    <span class="shrink-0 rounded-full border border-night-700 bg-night-800 px-2 py-0.5 text-[10px] uppercase tracking-wider text-slate-300">{item.deadline}</span>
                  )}
                </div>
                {item.description && <p class="mt-1 text-sm text-slate-300">{item.description}</p>}
              </li>
            ))}
          </ul>
        </section>
      );
    })}
  </div>
</Base>
