---
import Base from '../layouts/Base.astro';
import { lodging } from '../data/lodging';
import { eclipse } from '../data/eclipse';
import { families } from '../data/families';

function dateLabel(d: string): string {
  return new Date(`${d}T12:00:00`).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

function familyLabels(ids: string[]): string {
  if (ids.length === 0) return 'Everyone';
  return ids
    .map((id) => families.find((f) => f.id === id)?.name ?? id)
    .join(' · ');
}

const lodgingPins = lodging
  .filter((l) => l.coords)
  .map((l) => ({
    kind: 'lodging' as const,
    id: l.id,
    coords: l.coords!,
    name: l.name,
    dates: `${dateLabel(l.checkInDate)} – ${dateLabel(l.checkOutDate)}`,
    families: familyLabels(l.families),
    host: l.host ?? null,
    mapQuery: l.mapQuery ?? l.address ?? l.name,
  }));

const eclipsePins = eclipse.viewingOptions
  .filter((opt: { coords?: [number, number] | null }) => opt.coords)
  .map((opt: { id: string; name: string; coords: [number, number]; mapQuery?: string | null }) => ({
    kind: 'eclipse' as const,
    id: opt.id,
    coords: opt.coords,
    name: opt.name,
    mapQuery: opt.mapQuery ?? opt.name,
  }));

const allPins = [...lodgingPins, ...eclipsePins];
const pinsJson = JSON.stringify(allPins);
---

<Base title="Map">
  <header class="mb-4">
    <h1 class="text-2xl font-bold tracking-tight text-fg-strong sm:text-3xl">Trip Map</h1>
    <p class="mt-1 text-sm text-fg-muted">Every stay and the known eclipse viewing options. Tap a pin for details.</p>
  </header>

  <div id="trip-map" class="h-[70vh] min-h-[420px] rounded-2xl border border-line bg-card overflow-hidden"></div>

  <div class="mt-4 flex flex-wrap gap-4 text-xs text-fg-muted">
    <span class="inline-flex items-center gap-2">
      <span class="inline-block h-3 w-3 rounded-full bg-sun-500 ring-2 ring-card"></span>
      Lodging ({lodgingPins.length})
    </span>
    <span class="inline-flex items-center gap-2">
      <span class="inline-block h-3 w-3 rounded-full bg-violet-500 ring-2 ring-card"></span>
      Eclipse viewing ({eclipsePins.length})
    </span>
    {eclipse.viewingOptions.length > eclipsePins.length && (
      <span class="text-fg-subtle italic">
        ({eclipse.viewingOptions.length - eclipsePins.length} eclipse option{eclipse.viewingOptions.length - eclipsePins.length === 1 ? '' : 's'} not pinned — location TBD)
      </span>
    )}
  </div>

  <p class="mt-3 text-xs text-fg-subtle">Map tiles: © OpenStreetMap contributors © CARTO. Tiles aren't cached offline — needs a connection to load.</p>
</Base>

<script type="application/json" id="map-pins" set:html={pinsJson}></script>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  type Pin =
    | {
        kind: 'lodging';
        id: string;
        coords: [number, number];
        name: string;
        dates: string;
        families: string;
        host: string | null;
        mapQuery: string;
      }
    | {
        kind: 'eclipse';
        id: string;
        coords: [number, number];
        name: string;
        mapQuery: string;
      };

  const dataEl = document.getElementById('map-pins');
  const pins: Pin[] = dataEl ? JSON.parse(dataEl.textContent || '[]') : [];

  const container = document.getElementById('trip-map');
  if (container && pins.length > 0) {
    const map = L.map(container, { scrollWheelZoom: false });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors © <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19,
    }).addTo(map);

    const colorByKind: Record<Pin['kind'], string> = {
      lodging: '#f59e0b', // sun-500
      eclipse: '#8b5cf6', // violet-500
    };

    function mapsHref(query: string): string {
      return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`;
    }

    function escapeHtml(s: string): string {
      return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
    }

    function popupHtml(p: Pin): string {
      const dirsLink = `<a href="${mapsHref(p.mapQuery)}" target="_blank" rel="noopener" style="color:#0284c7;text-decoration:underline;">Get directions ↗</a>`;
      if (p.kind === 'lodging') {
        return `
          <div style="font-family:system-ui,-apple-system,Inter,sans-serif;min-width:180px;">
            <div style="font-weight:600;color:#0f172a;">${escapeHtml(p.name)}</div>
            <div style="font-size:11px;color:#64748b;margin-top:2px;">${escapeHtml(p.dates)}${p.host ? ` · ${escapeHtml(p.host)}` : ''}</div>
            <div style="font-size:11px;color:#475569;margin-top:6px;">${escapeHtml(p.families)}</div>
            <div style="margin-top:8px;font-size:12px;">${dirsLink}</div>
          </div>
        `;
      }
      return `
        <div style="font-family:system-ui,-apple-system,Inter,sans-serif;min-width:180px;">
          <div style="font-weight:600;color:#0f172a;">${escapeHtml(p.name)}</div>
          <div style="font-size:11px;color:#64748b;margin-top:2px;">Eclipse viewing option</div>
          <div style="margin-top:8px;font-size:12px;">${dirsLink}</div>
        </div>
      `;
    }

    const markers: L.Layer[] = [];
    for (const p of pins) {
      const m = L.circleMarker(p.coords, {
        radius: 8,
        fillColor: colorByKind[p.kind],
        color: '#ffffff',
        weight: 2,
        fillOpacity: 0.95,
      }).bindPopup(popupHtml(p), { closeButton: true, maxWidth: 260 });
      m.addTo(map);
      markers.push(m);
    }

    const bounds = L.featureGroup(markers).getBounds().pad(0.18);
    map.fitBounds(bounds);
    if (map.getZoom() > 9) map.setZoom(9);
  }
</script>

<style is:global>
  /* Leaflet popups use Tailwind-incompatible inline styles; theme the container
     so it doesn't fight the rest of the page. */
  .leaflet-container {
    background: var(--color-card-2);
    font-family: inherit;
  }
  .leaflet-popup-content-wrapper,
  .leaflet-popup-tip {
    background: #ffffff;
    color: #0f172a;
  }
  .leaflet-control-attribution {
    background: rgba(255, 255, 255, 0.85);
    font-size: 10px;
  }
  .dark .leaflet-control-attribution {
    background: rgba(11, 18, 32, 0.85);
    color: var(--color-fg-muted);
  }
  .dark .leaflet-control-attribution a {
    color: var(--color-fg-muted);
  }
</style>
