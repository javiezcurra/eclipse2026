---
import Base from '../layouts/Base.astro';
import TimelineItem from '../components/TimelineItem.astro';
import { sortedItinerary, itineraryDates } from '../data/itinerary';
import { families, familyColorClasses } from '../data/families';
import { flightById } from '../data/flights';
import { lodgingById } from '../data/lodging';

const events = sortedItinerary();
const dates = itineraryDates();

function dateLabel(d: string): string {
  return new Date(`${d}T12:00:00`).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });
}
function dateShortLabel(d: string): string {
  return new Date(`${d}T12:00:00`).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}

const eventsByDate = new Map<string, typeof events>();
for (const e of events) {
  const list = eventsByDate.get(e.date) ?? [];
  list.push(e);
  eventsByDate.set(e.date, list);
}
---

<Base>
  <header class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight text-fg-strong sm:text-3xl">Itinerary</h1>
  </header>

  <!-- Family filters -->
  <section class="mb-4 rounded-xl border border-line bg-card p-3">
    <p class="mb-2 text-[11px] font-semibold uppercase tracking-wider text-fg-muted">Filter by family</p>
    <div id="family-filter" class="flex flex-wrap gap-2" data-active="all">
      <button type="button" data-family="all" class="filter-chip filter-chip-active rounded-full border border-line-strong bg-card-2 px-3 py-1 text-xs font-medium text-fg-strong">All</button>
      {families.map((f) => {
        const c = familyColorClasses[f.color];
        return (
          <button
            type="button"
            data-family={f.id}
            class:list={['filter-chip rounded-full border px-3 py-1 text-xs font-medium', c.bgSoft, c.text, c.border]}
          >
            <span class:list={['mr-1 inline-block h-1.5 w-1.5 rounded-full align-middle', c.dot]}></span>
            {f.name}
          </button>
        );
      })}
    </div>
    <p class="mt-2 text-[11px] text-fg-subtle">Showing events for the selected family plus all "everyone" events.</p>
  </section>

  <!-- Jump-to-date pills -->
  <section class="mb-6 -mx-1 overflow-x-auto">
    <div class="flex gap-2 px-1 pb-2">
      {dates.map((d) => (
        <a href={`#day-${d}`} class="shrink-0 rounded-full border border-line bg-card px-3 py-1.5 text-xs font-medium text-fg-muted hover:border-line-strong hover:text-fg-strong">
          {dateShortLabel(d)}
        </a>
      ))}
    </div>
  </section>

  <!-- Timeline -->
  <div class="space-y-8">
    {dates.map((d) => (
      <section id={`day-${d}`} class="scroll-mt-20 day-section" data-date={d}>
        <header class="mb-4 flex items-baseline justify-between border-b border-line pb-2">
          <h2 class="text-lg font-semibold text-fg-strong">{dateLabel(d)}</h2>
          <span class="text-xs text-fg-subtle">{d}</span>
        </header>
        <div class="space-y-0">
          {eventsByDate.get(d)?.map((e) => (
            <TimelineItem
              event={e}
              flight={e.type === 'flight' && e.refId ? flightById(e.refId) : undefined}
              lodging={(e.type === 'lodging-checkin' || e.type === 'lodging-checkout') && e.refId ? lodgingById(e.refId) : undefined}
            />
          ))}
        </div>
      </section>
    ))}
  </div>

  <p id="empty-state" class="hidden rounded-xl border border-dashed border-line-strong p-6 text-center text-sm text-fg-muted">
    No events match this filter.
  </p>
</Base>

<script>
  // ── Setup ───────────────────────────────────────────────────────────
  const FILTER_KEY = 'itinerary-family-filter';

  const container = document.getElementById('family-filter');
  const chips = container ? Array.from(container.querySelectorAll<HTMLButtonElement>('.filter-chip')) : [];
  const items = Array.from(document.querySelectorAll<HTMLElement>('.timeline-item'));
  const daySections = Array.from(document.querySelectorAll<HTMLElement>('.day-section'));
  const empty = document.getElementById('empty-state');

  function applyFilter(family: string) {
    let visibleCount = 0;
    for (const el of items) {
      const everyone = el.dataset.everyone === 'true';
      const fams = (el.dataset.families || '').split(',').filter(Boolean);
      const show = family === 'all' || everyone || fams.includes(family);
      el.classList.toggle('hidden', !show);
      if (show) visibleCount++;
    }
    for (const section of daySections) {
      const anyVisible = section.querySelectorAll('.timeline-item:not(.hidden)').length > 0;
      section.classList.toggle('hidden', !anyVisible);
    }
    empty?.classList.toggle('hidden', visibleCount > 0);
  }

  function activateChip(family: string) {
    for (const c of chips) c.classList.remove('filter-chip-active', 'ring-2');
    const match = chips.find((c) => c.dataset.family === family)
              ?? chips.find((c) => c.dataset.family === 'all');
    match?.classList.add('filter-chip-active', 'ring-2');
    container?.setAttribute('data-active', family);
    applyFilter(family);
  }

  // ── Restore saved filter (runs synchronously before auto-scroll so the
  //    auto-scroll target check sees the correct hidden/visible state). ─
  try {
    const saved = localStorage.getItem(FILTER_KEY);
    if (saved && saved !== 'all' && chips.some((c) => c.dataset.family === saved)) {
      activateChip(saved);
    }
  } catch (_) {}

  // ── Auto-scroll to today's first visible section on load ────────────
  // Before the trip starts (or after it ends), stay at the top.
  // If the URL already has a hash, respect that and don't override.
  // Skips over day sections hidden by the active family filter.
  (function autoscrollToToday() {
    if (window.location.hash) return;

    const today = new Intl.DateTimeFormat('en-CA', {
      timeZone: 'Europe/Madrid',
      year: 'numeric', month: '2-digit', day: '2-digit',
    }).format(new Date());

    const dates = daySections
      .map((s) => s.dataset.date)
      .filter((d): d is string => Boolean(d))
      .sort();
    if (dates.length === 0) return;

    if (today < dates[0]) return;                 // before trip → stay at top
    if (today > dates[dates.length - 1]) return;  // after trip  → stay at top

    const target = dates.find((d) => {
      if (d < today) return false;
      const el = document.getElementById(`day-${d}`);
      return Boolean(el) && !el!.classList.contains('hidden');
    });
    if (!target) return;

    const el = document.getElementById(`day-${target}`);
    el?.scrollIntoView({ behavior: 'instant', block: 'start' });
  })();

  // ── Family filter chip clicks ──────────────────────────────────────
  for (const chip of chips) {
    chip.addEventListener('click', () => {
      const family = chip.dataset.family || 'all';
      activateChip(family);
      try {
        if (family === 'all') localStorage.removeItem(FILTER_KEY);
        else localStorage.setItem(FILTER_KEY, family);
      } catch (_) {}
    });
  }

  // ── Open flight / lodging detail modals ────────────────────────────
  for (const trigger of document.querySelectorAll<HTMLButtonElement>('[data-modal-target]')) {
    trigger.addEventListener('click', () => {
      const id = trigger.dataset.modalTarget;
      if (!id) return;
      const dialog = document.getElementById(id) as HTMLDialogElement | null;
      dialog?.showModal();
    });
  }

  for (const dialog of document.querySelectorAll<HTMLDialogElement>('dialog.modal')) {
    dialog.addEventListener('click', (e) => {
      const rect = dialog.getBoundingClientRect();
      const inside = e.clientX >= rect.left && e.clientX <= rect.right
                  && e.clientY >= rect.top && e.clientY <= rect.bottom;
      if (!inside) dialog.close();
    });
  }
</script>

<style>
  .filter-chip-active { box-shadow: 0 0 0 2px rgba(148,163,184,0.4); }
</style>
