---
import { sortedItinerary } from '../data/itinerary';
import { trip } from '../data/trip';

const events = sortedItinerary();

// Serialize events for client-side filtering (we don't know "now" at build time).
const payload = JSON.stringify(
  events.map((e) => ({
    id: e.id,
    date: e.date,
    startTime: e.startTime ?? null,
    endTime: e.endTime ?? null,
    type: e.type,
    title: e.title,
    location: e.location ?? null,
    families: e.families,
  })),
);
---

<section class="rounded-2xl border border-line bg-card p-5">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-fg-muted">Happening now</h2>
    <span id="now-clock" class="text-xs text-fg-subtle" data-tz={trip.timeZone}></span>
  </div>
  <div id="now-content" class="space-y-3 text-sm text-fg">
    <p class="text-fg-muted">Loading trip status…</p>
  </div>
</section>

<script type="application/json" id="itinerary-data" set:html={payload}></script>

<script>
  type Ev = {
    id: string; date: string; startTime: string | null; endTime: string | null;
    type: string; title: string; location: string | null; families: string[];
  };

  const dataEl = document.getElementById('itinerary-data');
  const events: Ev[] = dataEl ? JSON.parse(dataEl.textContent || '[]') : [];
  const tz = (document.getElementById('now-clock') as HTMLElement | null)?.dataset.tz || 'Europe/Madrid';

  function nowInTz(): { date: string; time: string; label: string } {
    const d = new Date();
    const dateFmt = new Intl.DateTimeFormat('en-CA', { timeZone: tz, year: 'numeric', month: '2-digit', day: '2-digit' });
    const timeFmt = new Intl.DateTimeFormat('en-GB', { timeZone: tz, hour: '2-digit', minute: '2-digit', hour12: false });
    const labelFmt = new Intl.DateTimeFormat('en-US', { timeZone: tz, weekday: 'short', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
    return { date: dateFmt.format(d), time: timeFmt.format(d), label: labelFmt.format(d) + ' Spain' };
  }

  function eventStart(e: Ev): string { return `${e.date}T${e.startTime ?? '00:00'}`; }
  function eventEnd(e: Ev): string {
    const t = e.endTime ?? e.startTime ?? '23:59';
    return `${e.date}T${t}`;
  }

  function render() {
    const { date, time, label } = nowInTz();
    const nowKey = `${date}T${time}`;
    const clock = document.getElementById('now-clock');
    if (clock) clock.textContent = label;

    const container = document.getElementById('now-content');
    if (!container) return;

    const sorted = [...events].sort((a, b) => eventStart(a).localeCompare(eventStart(b)));
    const happeningNow = sorted.filter((e) => eventStart(e) <= nowKey && eventEnd(e) >= nowKey);
    const upcoming = sorted.filter((e) => eventStart(e) > nowKey).slice(0, 3);

    let html = '';
    if (sorted.length === 0) {
      container.innerHTML = '<p class="text-fg-muted">No itinerary events yet.</p>';
      return;
    }

    const tripStart = sorted[0].date;
    const tripEnd = sorted[sorted.length - 1].date;
    if (date < tripStart) {
      const days = Math.ceil((Date.parse(tripStart) - Date.parse(date)) / 86400000);
      html += `<p class="text-base text-fg-strong"><span class="text-sun-500 dark:text-sun-400 font-semibold">${days} day${days === 1 ? '' : 's'}</span> until the trip starts.</p>`;
    } else if (date > tripEnd) {
      html += `<p class="text-fg-muted">The trip has ended. Hope it was amazing! 🌅</p>`;
    } else {
      if (happeningNow.length > 0) {
        html += '<div><p class="mb-1 text-[11px] uppercase tracking-wider text-emerald-600 dark:text-emerald-400">Now</p>';
        html += happeningNow.map(renderEvent).join('');
        html += '</div>';
      }
      if (upcoming.length > 0) {
        html += '<div><p class="mb-1 mt-3 text-[11px] uppercase tracking-wider text-sky-600 dark:text-sky-400">Up next</p>';
        html += upcoming.map(renderEvent).join('');
        html += '</div>';
      }
      if (happeningNow.length === 0 && upcoming.length === 0) {
        html += '<p class="text-fg-muted">Nothing else scheduled.</p>';
      }
    }
    container.innerHTML = html;
  }

  function renderEvent(e: Ev): string {
    const dateLabel = new Date(`${e.date}T12:00:00`).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
    const time = e.startTime ? `${e.startTime}${e.endTime ? `–${e.endTime}` : ''}` : 'all day';
    const loc = e.location ? ` · ${e.location}` : '';
    return `<div class="rounded-lg border border-line bg-card-2 px-3 py-2">
      <div class="text-xs text-fg-subtle">${dateLabel} · ${time}${loc}</div>
      <div class="font-medium text-fg-strong">${e.title}</div>
    </div>`;
  }

  render();
  setInterval(render, 60_000);
</script>
