---
import type { Flight } from '../data/types';
import FamilyChips from './FamilyChips.astro';
import StatusBadge from './StatusBadge.astro';
import { flightTrackingUrl } from '../lib/flight';

interface Props {
  flight: Flight;
  /** Stable id used to wire the trigger button to this dialog. */
  modalId: string;
}
const { flight, modalId } = Astro.props;

function dateLabel(d: string): string {
  return new Date(`${d}T12:00:00`).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });
}

const sameDay = flight.departDate === flight.arriveDate;
const trackUrl = flightTrackingUrl(flight.flightNumber);
const titleId = `${modalId}-title`;
---

<dialog
  id={modalId}
  aria-labelledby={titleId}
  class="modal w-[min(100%-1.5rem,38rem)] rounded-2xl border border-line bg-card p-0 text-fg backdrop:bg-black/60 backdrop:backdrop-blur-sm"
>
  <form method="dialog" class="contents">
    <header class="flex items-start justify-between gap-3 border-b border-line px-5 py-4">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-wider text-fg-subtle">{flight.airline}</p>
        <h2 id={titleId} class="mt-0.5 text-lg font-bold text-fg-strong">{flight.flightNumber}</h2>
      </div>
      <button
        type="submit"
        value="close"
        class="-mr-2 -mt-2 rounded-md p-2 text-fg-muted hover:bg-card-2 hover:text-fg-strong"
        aria-label="Close"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </header>

    <div class="space-y-5 px-5 py-5">
      <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3">
        <div>
          <p class="text-2xl font-bold text-fg-strong sm:text-3xl">{flight.departAirport}</p>
          <p class="mt-1 text-base font-semibold text-fg">{flight.departTime}</p>
          <p class="text-xs text-fg-muted">{dateLabel(flight.departDate)}</p>
          <p class="mt-1 text-xs text-fg-subtle">{flight.departAirportName}</p>
        </div>
        <div class="flex flex-col items-center text-fg-subtle">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          {flight.duration && <p class="mt-1 text-[11px] font-medium uppercase tracking-wider">{flight.duration}</p>}
        </div>
        <div class="text-right">
          <p class="text-2xl font-bold text-fg-strong sm:text-3xl">{flight.arriveAirport}</p>
          <p class="mt-1 text-base font-semibold text-fg">
            {flight.arriveTime}
            {!sameDay && <span class="ml-1 text-[10px] align-top text-sun-600 dark:text-sun-400">+1</span>}
          </p>
          <p class="text-xs text-fg-muted">{dateLabel(flight.arriveDate)}</p>
          <p class="mt-1 text-xs text-fg-subtle">{flight.arriveAirportName}</p>
        </div>
      </div>

      <dl class="grid gap-3 rounded-xl border border-line bg-card-2 p-4 text-sm sm:grid-cols-2">
        {flight.aircraft && (
          <div>
            <dt class="text-[11px] uppercase tracking-wider text-fg-subtle">Aircraft</dt>
            <dd class="text-fg">{flight.aircraft}</dd>
          </div>
        )}
        {flight.fareClass && (
          <div>
            <dt class="text-[11px] uppercase tracking-wider text-fg-subtle">Fare</dt>
            <dd class="text-fg">{flight.fareClass}</dd>
          </div>
        )}
        {flight.confirmation && (
          <div>
            <dt class="text-[11px] uppercase tracking-wider text-fg-subtle">Confirmation</dt>
            <dd class="font-mono text-fg-strong">{flight.confirmation}</dd>
          </div>
        )}
        {flight.operatedBy && (
          <div>
            <dt class="text-[11px] uppercase tracking-wider text-fg-subtle">Operated by</dt>
            <dd class="text-fg">{flight.operatedBy}</dd>
          </div>
        )}
        <div class="sm:col-span-2 flex items-center gap-2">
          <dt class="text-[11px] uppercase tracking-wider text-fg-subtle">Status</dt>
          <dd><StatusBadge status={flight.status} /></dd>
        </div>
      </dl>

      <div>
        <p class="mb-2 text-[11px] font-semibold uppercase tracking-wider text-fg-subtle">Travelers ({flight.travelers.length})</p>
        <ul class="grid gap-1 text-sm text-fg sm:grid-cols-2">
          {flight.travelers.map((t) => <li>· {t}</li>)}
        </ul>
        <div class="mt-3">
          <FamilyChips ids={flight.families} size="md" />
        </div>
      </div>

      {flight.notes && (
        <p class="text-xs text-fg-muted">{flight.notes}</p>
      )}
    </div>

    <footer class="flex flex-col-reverse gap-2 border-t border-line px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
      <button
        type="submit"
        value="close"
        class="rounded-lg border border-line px-4 py-2 text-sm font-medium text-fg hover:bg-card-2"
      >
        Close
      </button>
      {flight.status === 'needs-action' ? (
        <span class="rounded-lg border border-dashed border-line-strong px-4 py-2 text-xs text-fg-muted">Tracking available once flight is booked</span>
      ) : (
        <a
          href={trackUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-sun-500 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-sun-400"
        >
          Track on FlightAware
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
        </a>
      )}
    </footer>
  </form>
</dialog>

