---
import { trip } from '../data/trip';
---

<footer class="mt-12 border-t border-line py-6 text-center text-xs text-fg-subtle">
  <p>{trip.name} · Total solar eclipse, {new Date(trip.eclipseDate).toLocaleDateString('en-US', { dateStyle: 'long' })}</p>
  <p class="mt-1">All times shown in Spain local time (CEST, UTC+2) unless noted.</p>
</footer>
