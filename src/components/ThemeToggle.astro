---
// Light/dark theme toggle. Persists choice in localStorage under `theme`.
// The anti-FOUC inline script in Base.astro applies the initial class on <html>
// before paint, so the toggle just flips it.
---

<button
  id="theme-toggle"
  type="button"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-line text-fg-muted hover:bg-card-2 hover:text-fg-strong"
  aria-label="Toggle light / dark mode"
  title="Toggle theme"
>
  <svg id="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
  </svg>
  <svg id="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle');
  const sun = document.getElementById('theme-icon-sun');
  const moon = document.getElementById('theme-icon-moon');

  function syncIcons() {
    const dark = document.documentElement.classList.contains('dark');
    sun?.classList.toggle('hidden', !dark);   // sun shown in dark mode (suggests "switch to light")
    moon?.classList.toggle('hidden', dark);   // moon shown in light mode (suggests "switch to dark")
  }
  syncIcons();

  btn?.addEventListener('click', () => {
    const next = document.documentElement.classList.contains('dark') ? 'light' : 'dark';
    document.documentElement.classList.toggle('dark', next === 'dark');
    try { localStorage.setItem('theme', next); } catch {}
    syncIcons();
  });

  // Keep tabs in sync if user toggles in another window.
  window.addEventListener('storage', (e) => {
    if (e.key !== 'theme') return;
    document.documentElement.classList.toggle('dark', e.newValue === 'dark');
    syncIcons();
  });
</script>
