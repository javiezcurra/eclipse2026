---
import { familyById, familyColorClasses } from '../data/families';

interface Props {
  ids: string[];
  size?: 'sm' | 'md';
}
const { ids, size = 'sm' } = Astro.props;
const isEveryone = ids.length === 0;
const padding = size === 'sm' ? 'px-2 py-0.5 text-[11px]' : 'px-2.5 py-1 text-xs';
---

{isEveryone ? (
  <span class:list={['inline-flex items-center rounded-full border border-line-strong bg-card-2 font-medium text-fg', padding]}>Everyone</span>
) : (
  <span class="inline-flex flex-wrap gap-1">
    {ids.map((id) => {
      const fam = familyById(id);
      if (!fam) return null;
      const c = familyColorClasses[fam.color];
      return (
        <span class:list={['inline-flex items-center gap-1 rounded-full border font-medium', padding, c.bgSoft, c.text, c.border]}>
          <span class:list={['h-1.5 w-1.5 rounded-full', c.dot]}></span>
          {fam.name}
        </span>
      );
    })}
  </span>
)}
