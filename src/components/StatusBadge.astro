---
import type { EventStatus } from '../data/types';

interface Props {
  status: EventStatus;
}
const { status } = Astro.props;

const styles: Record<EventStatus, { label: string; classes: string }> = {
  confirmed:      { label: 'Confirmed',     classes: 'bg-emerald-500/15 text-emerald-300 border-emerald-500/30' },
  booked:         { label: 'Booked',        classes: 'bg-sky-500/15 text-sky-300 border-sky-500/30' },
  tentative:      { label: 'Tentative',     classes: 'bg-amber-500/15 text-amber-300 border-amber-500/30' },
  'needs-action': { label: 'Needs action',  classes: 'bg-rose-500/15 text-rose-300 border-rose-500/30' },
};
const s = styles[status];
---

<span class:list={['inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide', s.classes]}>
  {s.label}
</span>
